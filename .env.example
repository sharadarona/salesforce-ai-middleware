# ════════════════════════════════════════════════════════════════
#  .env.example  —  Copy to .env and fill in your values
#  NEVER commit the real .env file to Git
# ════════════════════════════════════════════════════════════════

# OpenAI API Key (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Secret key sent by Salesforce Named Credential in X-API-Key header
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
MIDDLEWARE_API_KEY=change-this-to-a-strong-random-secret

# LLM model to use (gpt-4o-mini is cheapest, gpt-4o is most accurate)
OPENAI_MODEL=gpt-4o-mini

# Response token limit (higher = more detailed summary, more cost)
MAX_TOKENS=500

# Temperature: 0.0 = deterministic, 1.0 = creative (keep low for summaries)
TEMPERATURE=0.1

# CORS origins (comma-separated). Use * for dev, restrict in production.
ALLOWED_ORIGINS=*
